{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sansheng.dev/spec/life_event.schema.json",
  "title": "生命事件 LifeEvent v0.1",
  "description": "生命的最小存在单位。只增不改；双时间；带向量时钟以支持一体多身同步（SPEC/life_event.md + sync_merge.md）。",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^evt_[a-z0-9][a-z0-9_-]{0,63}$" },
    "life_id": { "$ref": "common_defs.schema.json#/$defs/LifeId" },
    "event_time": { "$ref": "common_defs.schema.json#/$defs/Timestamp" },
    "record_time": { "$ref": "common_defs.schema.json#/$defs/Timestamp" },
    "source": { "$ref": "common_defs.schema.json#/$defs/EventSource" },
    "actor": { "$ref": "common_defs.schema.json#/$defs/Actor" },
    "permission": { "$ref": "common_defs.schema.json#/$defs/TrustLevel" },
    "risk": { "$ref": "common_defs.schema.json#/$defs/RiskLevel" },
    "content": { "type": "object" },
    "content_hash": { "$ref": "common_defs.schema.json#/$defs/Hash" },
    "device_id": { "$ref": "common_defs.schema.json#/$defs/DeviceId" },
    "vector_clock": { "$ref": "common_defs.schema.json#/$defs/VectorClock" },
    "evidence_hash": { "$ref": "common_defs.schema.json#/$defs/Hash" },
    "cost": { "$ref": "common_defs.schema.json#/$defs/Cost" },
    "result": { "type": "object" },
    "confirmation": {
      "type": "object",
      "description": "资金/对外发布/设备动作事件必须带确认状态与补偿方案",
      "properties": {
        "status": { "enum": ["not_required", "pending", "confirmed", "rejected", "compensated"] },
        "compensation": { "type": "string" }
      },
      "required": ["status"],
      "additionalProperties": false
    },
    "signature": { "type": "string" }
  },
  "required": ["id", "life_id", "event_time", "record_time", "source", "actor", "risk", "content", "content_hash", "device_id", "vector_clock"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "risk": { "enum": ["A3", "A4"] } } },
      "then": { "required": ["confirmation"] }
    }
  ]
}
