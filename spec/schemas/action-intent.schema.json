{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sansheng.local/v0.1/action-intent.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "intent_id", "life_id", "requested_by", "mode", "action_type", "action_risk", "trust_level", "side_effect", "reversible", "authorized", "created_at"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "intent_id": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/Uuid" },
    "life_id": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/Uuid" },
    "requested_by": { "anyOf": [{ "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/CoreId" }, { "enum": ["owner", "system"] }] },
    "mode": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/IntentMode" },
    "action_type": { "type": "string", "minLength": 1 },
    "action_risk": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/ActionRisk" },
    "trust_level": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/TrustLevel" },
    "side_effect": { "type": "boolean" },
    "reversible": { "type": "boolean" },
    "authorized": { "type": "boolean" },
    "grant_id": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "created_at": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/IsoTimestamp" }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "enum": ["discuss", "draft", "simulate"] } } },
      "then": { "properties": { "side_effect": { "const": false } } }
    },
    {
      "if": { "properties": { "authorized": { "const": true }, "mode": { "const": "act" } }, "required": ["authorized", "mode"] },
      "then": {
        "properties": { "grant_id": { "type": "string", "minLength": 1 } },
        "required": ["grant_id"]
      }
    }
  ]
}
