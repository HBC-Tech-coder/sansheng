{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sansheng.dev/spec/model_gateway.schema.json",
  "title": "多模型混血网关 v0.1",
  "description": "突破 Hermes 单模型限制。三核可绑不同生父；L2/L3 可多模型并行融合（SPEC/model_gateway.md）。",
  "type": "object",
  "$defs": {
    "ModelProfile": {
      "type": "object",
      "properties": {
        "ref": { "$ref": "common_defs.schema.json#/$defs/ModelRef" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "cost_per_1k_in": { "type": "number", "minimum": 0 },
        "cost_per_1k_out": { "type": "number", "minimum": 0 },
        "latency_ms_avg": { "type": "integer", "minimum": 0 },
        "context_window": { "type": "integer", "minimum": 1 },
        "residency": { "enum": ["domestic", "overseas", "local"], "description": "数据驻留：国内/境外/本地——跨境发送需授权" }
      },
      "required": ["ref", "residency"],
      "additionalProperties": false
    }
  },
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "task_type": { "enum": ["chat", "reason", "code", "vision", "embed", "tool"] },
        "messages": { "type": "array" },
        "model": {
          "oneOf": [
            { "$ref": "common_defs.schema.json#/$defs/ModelRef" },
            { "const": "auto" }
          ]
        },
        "account_mode": { "enum": ["platform_default", "byo_key", "enterprise_hosted"], "description": "创始人定：平台默认/自带Key/企业托管三选一" },
        "stream": { "type": "boolean" },
        "budget": {
          "type": "object",
          "properties": {
            "max_tokens": { "type": "integer", "minimum": 1 },
            "max_cost": { "$ref": "common_defs.schema.json#/$defs/Money" }
          },
          "additionalProperties": false
        },
        "allow_cross_border": { "type": "boolean", "default": false }
      },
      "required": ["task_type", "messages", "model", "account_mode"],
      "additionalProperties": false
    },
    "fusion": {
      "type": "object",
      "description": "L2/L3 多模型融合策略——0.1 先支持枚举，具体权重留 ADR",
      "properties": {
        "strategy": { "enum": ["single", "parallel_merge", "write_then_review", "judge"] },
        "members": { "type": "array", "items": { "$ref": "common_defs.schema.json#/$defs/ModelRef" }, "minItems": 1 }
      },
      "required": ["strategy", "members"],
      "additionalProperties": false
    }
  },
  "required": ["request"],
  "additionalProperties": false
}
