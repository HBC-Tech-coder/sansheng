{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sansheng.local/v0.1/sync-envelope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sync_id", "life_id", "source_device_id", "target_device_id", "source_clock", "source_head", "events", "created_at"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "sync_id": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/Uuid" },
    "life_id": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/Uuid" },
    "source_device_id": { "type": "string", "minLength": 1 },
    "target_device_id": { "type": "string", "minLength": 1 },
    "source_clock": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/VectorClock" },
    "source_head": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/Sha256" },
    "events": { "type": "array", "items": { "$ref": "https://schemas.sansheng.local/v0.1/life-event.schema.json" } },
    "merge_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["receipt_id", "object_type", "resolution", "resolver", "created_at"],
        "properties": {
          "receipt_id": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/Uuid" },
          "object_type": { "enum": ["event", "fact", "preference", "capability", "value", "constitution"] },
          "resolution": { "enum": ["union", "supersedes", "reconciled", "owner_required", "tamper_alert"] },
          "resolver": { "enum": ["deterministic", "metabolism", "owner", "immunity"] },
          "created_at": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/IsoTimestamp" }
        }
      }
    },
    "created_at": { "$ref": "https://schemas.sansheng.local/v0.1/common-defs.schema.json#/$defs/IsoTimestamp" }
  }
}

