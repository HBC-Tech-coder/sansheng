{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sansheng.dev/spec/lifepack.schema.json",
  "title": "LifePack manifest.json v0.1",
  "description": "生命包迁移/恢复/换脑/继承清单。基因组永不进主包（走独立冷库）。恢复=在另一台机器恢复出同一 Life ID（SPEC/lifepack.md）。",
  "type": "object",
  "properties": {
    "schema_version": { "const": "0.1" },
    "life_id": { "$ref": "common_defs.schema.json#/$defs/LifeId" },
    "parent_hash": { "$ref": "common_defs.schema.json#/$defs/Hash", "description": "分叉/繁殖时的父系哈希" },
    "created_at": { "$ref": "common_defs.schema.json#/$defs/Timestamp" },
    "created_on_device": { "$ref": "common_defs.schema.json#/$defs/DeviceId" },
    "vector_clock": { "$ref": "common_defs.schema.json#/$defs/VectorClock" },
    "sections": {
      "type": "object",
      "description": "各目录的哈希与对象数",
      "propertyNames": { "enum": ["identity", "constitution", "events", "memories", "evidence", "genes", "models", "relationships", "bodies", "recovery"] },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "hash": { "$ref": "common_defs.schema.json#/$defs/Hash" },
          "object_count": { "type": "integer", "minimum": 0 },
          "encrypted": { "type": "boolean" }
        },
        "required": ["hash", "encrypted"],
        "additionalProperties": false
      }
    },
    "excludes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "必须显式声明不打包的内容",
      "contains": { "const": "raw_genome" }
    },
    "recovery_verified": {
      "type": "object",
      "properties": {
        "restored_on_device": { "$ref": "common_defs.schema.json#/$defs/DeviceId" },
        "identity_regression_passed": { "type": "boolean" },
        "model_swap_tested": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "signature": { "type": "string" }
  },
  "required": ["schema_version", "life_id", "created_at", "sections", "excludes", "signature"],
  "additionalProperties": false
}
